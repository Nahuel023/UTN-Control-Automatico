%----------------------------------------------------------------------
% FORMATO DE TÍTULOS
%----------------------------------------------------------------------
\usepackage{titlesec}

\titleformat{\chapter}[display]
  {\normalfont\huge\bfseries\color{utnblue}}
  {\normalsize\color{utngray}\MakeUppercase{\chaptertitlename}\enspace\thechapter}
  {10pt}
  {\Huge}
  [\vspace{4pt}{\color{utnblue}\rule{\textwidth}{2.5pt}}]
\titlespacing*{\chapter}{0pt}{-10pt}{30pt}

\titleformat{\section}
  {\normalfont\Large\bfseries\color{utnblue}}
  {\thesection}{0.8em}{}
  [{\color{utnmidblue}\titlerule[0.4pt]}]
\titlespacing*{\section}{0pt}{2.2ex plus 0.5ex minus 0.3ex}{1ex plus 0.3ex}

\titleformat{\subsection}
  {\normalfont\large\bfseries\color{utngray}}
  {\thesubsection}{0.8em}{}
\titlespacing*{\subsection}{0pt}{1.8ex plus 0.3ex}{0.6ex plus 0.2ex}

\titleformat{\subsubsection}
  {\normalfont\normalsize\bfseries\color{utngray}}
  {\thesubsubsection}{0.8em}{}

