\usepackage{tikz}
\usepackage[american, straightvoltages]{circuitikz}
\usetikzlibrary{
  babel,              % resuelve conflicto entre TikZ y babel (activa >,<)
  arrows.meta,
  positioning,
  shapes.geometric,
  shapes.misc,
  calc,
  decorations.pathreplacing,
  decorations.markings,
  matrix,
  fit,
  backgrounds,
  patterns,
  intersections
}

%% Estilos globales para diagramas de bloques de control
\tikzset{
  >=Stealth,
  %% Bloque estándar
  block/.style={
    draw=utnblue, fill=utnlightblue, rectangle, rounded corners=2pt,
    minimum height=2.4em, minimum width=5.5em,
    font=\small, align=center, line width=0.7pt
  },
  %% Bloque pequeño
  smallblock/.style={
    draw=utnblue, fill=utnlightblue, rectangle, rounded corners=2pt,
    minimum height=1.9em, minimum width=3.5em,
    font=\footnotesize, align=center, line width=0.6pt
  },
  %% Nodo sumador (círculo)
  sumnode/.style={
    draw=utnblue, fill=white, circle,
    minimum size=0.9cm, font=\small, line width=0.7pt
  },
  %% Coordenadas para flechas
  input/.style={coordinate},
  output/.style={coordinate},
  junction/.style={circle, fill=utnblue, inner sep=1.5pt}
}

