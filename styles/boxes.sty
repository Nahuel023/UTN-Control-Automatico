%----------------------------------------------------------------------
% CAJA: CÓDIGO MATLAB (oscura, con minted)
%----------------------------------------------------------------------
\newtcblisting{matlabcode}[1][]{
  listing engine  = minted,
  minted language = matlab,
  minted options  = {
    fontsize   = \small,
    linenos    = true,
    numbersep  = 6pt,
    breaklines = true,
    tabsize    = 4
  },
  listing only,
  enhanced, breakable,
  colback   = colmatlabbg,
  colframe  = colmatlab!60!black,
  coltitle  = white,
  fonttitle = \bfseries\small,
  title     = {Código MATLAB},
  attach boxed title to top left = {yshift=-2mm, xshift=4mm},
  boxed title style = {
    colback=colmatlab, colframe=colmatlab, sharp corners, left=4pt, right=4pt
  },
  sharp corners = south,
  left=8pt, right=6pt, top=8pt, bottom=6pt,
  #1
}

