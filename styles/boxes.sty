%% styles/boxes.sty
%% Definición de todas las cajas pedagógicas con tcolorbox
%% Apunte "Control Automático" — UTN IEE
\ProvidesPackage{boxes}[2024/01/01 Cajas tcolorbox UTN]

%----------------------------------------------------------------------
% CONTADORES POR CAPÍTULO
%----------------------------------------------------------------------
\newcounter{numejemplo}[chapter]
\renewcommand{\thenumejemplo}{\thechapter.\arabic{numejemplo}}

\newcounter{numejercicio}[chapter]
\renewcommand{\thenumejercicio}{\thechapter.\arabic{numejercicio}}

%----------------------------------------------------------------------
% CAJA: DEFINICIÓN (azul)
%----------------------------------------------------------------------
\newtcolorbox{definicion}[2][]{
  enhanced, breakable,
  colback   = coldef!7!white,
  colframe  = coldef,
  coltitle  = white,
  fonttitle = \bfseries\small,
  title     = {Definición:\enspace #2},
  attach boxed title to top left = {yshift=-2mm, xshift=4mm},
  boxed title style = {
    colback=coldef, colframe=coldef, sharp corners, left=3pt, right=3pt
  },
  sharp corners = south,
  left=6pt, right=6pt, top=8pt, bottom=6pt,
  before upper = {\setlength{\parskip}{4pt}},
  #1
}

